{
  "name": "parinda-clinic",
  "version": "1.0.1",
  "description": "Parinda Clinic Application",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --dir",
    "build:win": "electron-builder --win",
    "test:e2e": "playwright test --config=tests/e2e/config/playwright.config.js",
    "test:e2e:ui": "playwright test --config=tests/e2e/config/playwright.config.js --ui",
    "test:e2e:debug": "playwright test --config=tests/e2e/config/playwright.config.js --debug",
    "test:db": "node test-db.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "playwright": "^1.44.0"
  },
  "build": {
    "appId": "com.parindaclinic.app",
    "productName": "Parinda Clinic",
    "publish": [
      {
        "provider": "github",
        "owner": "fantazamak",
        "repo": "parinda-clinic"
      }
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*"
    ]
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "pdfjs-dist": "^3.11.174",
    "pdfkit": "^0.19.1"
  }
}
