{
  "name": "parinda-clinic-app",
  "version": "1.0.0",
  "description": "Local desktop application for Parinda Clinic built with Electron",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win"
  },
  "keywords": [
    "electron",
    "clinic",
    "pos",
    "patients"
  ],
  "author": "Parinda Clinic Team",
  "license": "ISC",
  "dependencies": {
    "pdfkit": "^0.15.0"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.parindaclinic.app",
    "productName": "Parinda Clinic",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Parinda Clinic"
    }
  }
}
